<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragment_trainer_manage_availibility"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/trainer_tool_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:title="Gym"
            app:menu="@menu/overflow_menu"
            android:layout_marginBottom="150dp"/>

        <!--
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gym"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="150dp"/>
        -->

        <Spinner
            android:id="@+id/trainer_time_availibility_spinner"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"/>
        <!-- This will hold all of the timeslots to choose from -->

        <CheckBox
            android:id="@+id/trainer_status_checkbox"
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:text="Unavailible"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/trainer_submit_status_button"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:textSize="24sp"
            android:layout_marginBottom="100dp"/>

        <Button
            android:id="@+id/trainer_back_home"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textSize="24sp"/>

    </LinearLayout>
    <!--
    <ImageButton
        android:id="@+id/trainer_options_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:background="@android:color/transparent"
        android:contentDescription="Options menu"
        android:src="@android:drawable/ic_menu_info_details"/>
    -->

</FrameLayout>