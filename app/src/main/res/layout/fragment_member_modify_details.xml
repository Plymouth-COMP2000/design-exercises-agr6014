<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragment_member_modify_details"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- TODO: Update blank fragment layout -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gym"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="150dp"/>

        <EditText
            android:id="@+id/member_firstname_change_type"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:autofillHints="name"
            android:hint="First name" />

        <EditText
            android:id="@+id/member_lastname_change_type"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:autofillHints="name"
            android:hint="Last name" />

        <EditText
            android:id="@+id/member_email_change_type"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress"
            android:hint="Email address" />

        <EditText
            android:id="@+id/member_phone_change_type"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:autofillHints="phone"
            android:hint="Phone number" />

        <Button
            android:id="@+id/member_submit_changes_button"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:textSize="24sp"
            android:layout_marginBottom="100dp"/>

        <Button
            android:id="@+id/member_back_home"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textSize="24sp" />

    </LinearLayout>

</FrameLayout>